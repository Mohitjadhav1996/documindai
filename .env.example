# Copy to .env and fill in values. Do not commit .env.
# ─── App ───────────────────────────────────────────
APP_NAME=DocuMind AI
APP_ENV=development
SECRET_KEY=change-me-use-a-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────
POSTGRES_USER=documind
POSTGRES_PASSWORD=documind_secret
POSTGRES_DB=documind_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://documind:documind_secret@postgres:5432/documind_db

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── OpenAI (RAG + Agent) ────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── File upload ───────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,docx,txt,md

# ─── CORS ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
